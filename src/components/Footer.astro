---
import {getCollection} from 'astro:content';
import {SITE_TITLE, NAV_ITEMS, SITE_AUTHOR} from '@/consts';
import {getWordCount} from '@/utils/readingTime';

const allBlogPosts = await getCollection('blog');
const totalArticles = allBlogPosts.length;

let totalWords = 0;
for (const post of allBlogPosts) {
  totalWords += getWordCount(post.body || '');
}

const currentYear = new Date().getFullYear();
const startYear = 2026;

const marqueeItems = [
  ...NAV_ITEMS,
  { label: `${Math.round(totalWords / 1000)}k 字`, href: '#' },
  { label: `${totalArticles} 篇文章`, href: '#' },
  { label: 'Astro', href: 'https://astro.build' },
  { label: 'Tailwind CSS', href: 'https://tailwindcss.com' },
];
---

<footer class="border-t border-gray-200/50 dark:border-gray-700/50 mt-16 overflow-hidden">
  <div class="marquee-track py-4 border-b border-gray-200/30 dark:border-gray-700/30">
    <div class="marquee-content">
      {[...marqueeItems, ...marqueeItems].map((item) => (
        <a
          href={item.href}
          class="marquee-item shrink-0 px-6 text-sm text-gray-400 dark:text-gray-500 hover:text-primary dark:hover:text-primary transition-colors whitespace-nowrap"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-sm text-gray-500 dark:text-gray-400">
      <span>&copy; {startYear}{currentYear > startYear ? ` - ${currentYear}` : ''} <a
              class="text-yellow-300 hover:underline" href="https://santisify.top">{SITE_AUTHOR}</a></span>
      <span class="hidden sm:inline text-gray-300 dark:text-gray-600">|</span>
      <span>
        Powered by <a href="https://astro.build" class="text-primary hover:underline">Astro</a> & <a href="https://tailwindcss.com/" class="text-cyan-500 hover:underline">Tailwind</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .marquee-track {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .marquee-content {
    display: flex;
    width: max-content;
    animation: marquee-scroll 30s linear infinite;
  }

  .marquee-item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .marquee-item::after {
    content: '·';
    position: absolute;
    right: -4px;
    color: var(--color-text-secondary);
    opacity: 0.3;
  }

  .marquee-item:last-child::after {
    content: '';
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initMarquee() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    gsap.registerPlugin(ScrollTrigger);

    const track = document.querySelector('.marquee-track');
    const content = document.querySelector('.marquee-content');
    if (!track || !content) return;

    const marqueeTl = gsap.to(content, {
      x: '-50%',
      duration: 30,
      ease: 'none',
      repeat: -1,
    });

    ScrollTrigger.create({
      trigger: track,
      start: 'top bottom',
      end: 'bottom top',
      onUpdate: (self) => {
        const velocity = Math.abs(self.getVelocity());
        const timeScale = velocity > 100 ? Math.max(0.5, 1 + velocity / 5000) : 1;
        marqueeTl.timeScale(timeScale);
      },
    });
  }

  initMarquee();
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initMarquee, 100);
  });
</script>
