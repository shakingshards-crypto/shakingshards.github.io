---
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_COVER } from '@/consts';
import { getWordCount } from '@/utils/readingTime';

const allBlogPosts = await getCollection('blog');
const sorted = allBlogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestPosts = sorted.slice(0, 5);

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<section class="relative overflow-hidden" data-hero>
  <div class="absolute inset-0" data-hero-parallax>
    <img
      src={SITE_COVER}
      alt=""
      class="w-full h-full object-cover scale-110"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/45 to-black/70"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="text-white">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 tracking-tight leading-tight hero-reveal" data-hero-reveal>
          {SITE_TITLE}
        </h1>
        <p class="text-lg sm:text-xl text-white/75 font-light mb-8 leading-relaxed hero-reveal" data-hero-reveal>
          {SITE_DESCRIPTION}
        </p>
        <div class="flex items-center gap-3 hero-reveal" data-hero-reveal>
          <a href="/archives" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 hover:bg-white/20 backdrop-blur-sm rounded-full text-sm font-medium transition-all">
            浏览文章
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/about" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium text-white/70 hover:text-white transition-all">
            了解更多
          </a>
        </div>
      </div>

      <div class="hero-reveal" data-hero-reveal>
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-5 border border-white/10">
          <h2 class="text-sm font-medium text-white/60 mb-4 flex items-center gap-2">
            <span class="w-1 h-4 bg-primary rounded-full inline-block"></span>
            最新文章
          </h2>
          <div class="space-y-0">
            {latestPosts.map((post, index) => (
              <a
                href={`/post/${post.id}`}
                class="flex items-center gap-4 py-3 border-b border-white/5 last:border-0 group hover:bg-white/5 rounded-lg px-2 -mx-2 transition-colors"
              >
                <span class="text-xs font-mono text-white/25 w-6 shrink-0">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-medium text-white/90 truncate group-hover:text-primary transition-colors">
                    {post.data.title}
                  </h3>
                  <div class="flex items-center gap-2 mt-0.5 text-xs text-white/40">
                    <time datetime={formatDate(post.data.date)}>{formatDate(post.data.date)}</time>
                    {post.data.category && (
                      <>
                        <span>·</span>
                        <span>{post.data.category}</span>
                      </>
                    )}
                  </div>
                </div>
                <svg class="w-4 h-4 text-white/20 group-hover:text-primary transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/30 animate-bounce hero-reveal" data-hero-reveal>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  function initHero() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    gsap.registerPlugin(ScrollTrigger);

    const hero = document.querySelector('[data-hero]');
    const parallaxLayer = document.querySelector('[data-hero-parallax]');
    const reveals = document.querySelectorAll('[data-hero-reveal]');

    if (!hero || !parallaxLayer) return;

    gsap.fromTo(parallaxLayer,
      { y: 0 },
      {
        y: 50,
        ease: 'none',
        scrollTrigger: {
          trigger: hero,
          start: 'top top',
          end: 'bottom top',
          scrub: true,
        },
      }
    );

    if (reveals.length > 0) {
      gsap.fromTo(reveals,
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.12,
          ease: 'power3.out',
          delay: 0.2,
        }
      );
    }
  }

  initHero();
  document.addEventListener('astro:after-swap', () => {
    setTimeout(initHero, 100);
  });
</script>
